# Neon Postgres Configuration
NEON_DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
# You can also use DATABASE_URL as fallback

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=replace-with-a-secure-random-secret
JWT_ACCESS_SECRET=replace-with-a-secure-random-secret
JWT_REFRESH_SECRET=replace-with-a-secure-random-secret
JWT_EXPIRE=7d
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Optional bootstrap defaults
SEED_ADMIN_EMAIL=admin@demo.com
SEED_ADMIN_PASSWORD=Admin@12345

# CORS Configuration
FRONTEND_URL=http://localhost:3000

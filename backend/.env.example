NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
NEON_DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# Auth secrets
JWT_ACCESS_SECRET=replace-with-a-32-character-or-longer-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-32-character-or-longer-random-secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

